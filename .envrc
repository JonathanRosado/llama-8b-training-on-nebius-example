# =============================================================================
# Dual-path PoC — environment bootstrap (direnv)
#
# This file follows the canonical pattern from the Nebius Solutions Library
# (soperator/installations/example/.envrc) and serves BOTH deployment paths in
# this repo:
#
#   * Path A — terraform/path-a/            (Slinky + NFS + no filesystem quota)
#   * Path B — soperator/installations/poc/ (Soperator + virtiofs + IB fabric)
#
# It runs automatically via direnv when you cd into this directory, and sets
# up everything Terraform needs:
#
#   1. Discovers the VPC subnet from the project
#   2. Creates (or finds) a dedicated service account for Terraform
#   3. Adds the SA to the tenant's editors group (required for resource creation)
#   4. Mints a short-lived access key for S3-compatible Object Storage auth
#   5. Creates (or finds) a versioned S3 bucket for Terraform remote state
#   6. Generates terraform_backend_override.tf for EACH path (distinct state keys
#      share one bucket so state never collides between paths)
#   7. Exports TF_VAR_* under both Soperator and Path A naming conventions so a
#      single .envrc feeds both variable schemas
#
# After sourcing: cd into either path and run terraform init → terraform apply.
# =============================================================================

# Defaults for the csa-hiring-sandboxO tenant. Override via env vars if needed.
NEBIUS_TENANT_ID="${NEBIUS_TENANT_ID:-tenant-e00zr420cdr0rzv9br}"
NEBIUS_PROJECT_ID="${NEBIUS_PROJECT_ID:-project-e02qt8kdpr00x4ag7thr64}"
NEBIUS_REGION="${NEBIUS_REGION:-eu-north2}"

# O11y (observability) can target a separate tenant. For the PoC, same tenant.
NEBIUS_OLLY_PROFILE="${NEBIUS_OLLY_PROFILE:-soperator-telemetry}"
NEBIUS_OLLY_TENANT_ID="${NEBIUS_OLLY_TENANT_ID:-$NEBIUS_TENANT_ID}"

# The nebius CLI installs to ~/.nebius/bin, which may not be in PATH by default.
export PATH="$HOME/.nebius/bin:$HOME/.local/bin:$PATH"

if [ -z "${NEBIUS_TENANT_ID}" ]; then
  echo "Error: NEBIUS_TENANT_ID is not set"
  return 1
fi

if [ -z "${NEBIUS_PROJECT_ID}" ]; then
  echo "Error: NEBIUS_PROJECT_ID is not set"
  return 1
fi

# region VPC subnet
# Auto-discover the first subnet in the project. PoC tenants typically have
# one default subnet. If multiple exist, this picks the first — sufficient
# for a single-region deployment.

NEBIUS_VPC_SUBNET_ID=$(nebius vpc subnet list \
  --parent-id "${NEBIUS_PROJECT_ID}" \
  --format json \
  | jq -r '.items[0].metadata.id')
export NEBIUS_VPC_SUBNET_ID

# endregion VPC subnet

# region Remote state

# region Service account
# Terraform needs a service account (SA) for S3 backend credentials. The SA
# is named "slurm-terraform-sa" to match the canonical Solutions Library
# convention. It's idempotent — finds the existing SA or creates a new one.

NEBIUS_SA_TERRAFORM_ID=$(nebius iam service-account list \
  --page-size 999 \
  --parent-id "${NEBIUS_PROJECT_ID}" \
  --format json \
  --page-size 1000 \
  | jq -r '.items[]? | select(.metadata.name == "slurm-terraform-sa").metadata.id')

if [ -z "$NEBIUS_SA_TERRAFORM_ID" ]; then
  NEBIUS_SA_TERRAFORM_ID=$(nebius iam service-account create \
    --parent-id "${NEBIUS_PROJECT_ID}" \
    --name 'slurm-terraform-sa' \
    --format json \
    | jq -r '.metadata.id')
  echo "Created new service account with ID: $NEBIUS_SA_TERRAFORM_ID"
else
  echo "Found existing service account with ID: $NEBIUS_SA_TERRAFORM_ID"
fi

# endregion Service account

# region `editors` group
# The SA needs the "editor" role to create/modify cloud resources (compute,
# K8s, storage). Nebius grants roles via group membership, not direct role
# binding. The "editors" group is a Nebius-standard group that exists in every
# tenant and carries the editor role at tenant scope.

NEBIUS_GROUP_EDITORS_ID=$(nebius iam group get-by-name \
  --parent-id "${NEBIUS_TENANT_ID}" \
  --name 'editors' \
  --format json \
  | jq -r '.metadata.id')

IS_MEMBER=$(nebius iam group-membership list-members \
  --parent-id "${NEBIUS_GROUP_EDITORS_ID}" \
  --page-size 1000 \
  --format json \
  | jq -r --arg SAID "${NEBIUS_SA_TERRAFORM_ID}" '.memberships[] | select(.spec.member_id == $SAID) | .spec.member_id')

if [ -z "${IS_MEMBER}" ]; then
  nebius iam group-membership create \
    --parent-id "${NEBIUS_GROUP_EDITORS_ID}" \
    --member-id "${NEBIUS_SA_TERRAFORM_ID}"
  echo "Added service account to editors group"
else
  echo "Service account is already a member of editors group"
fi

# endregion `editors` group

# region Access key + S3 backend
# Access keys are AWS-compatible credentials (key ID + secret) that authenticate
# to Nebius Object Storage via the S3 API. They're minted for the SA, not the
# human user, so Terraform's state backend uses machine credentials.
#
# Keys are short-lived (1-day expiry) as a security practice — every direnv
# reload mints a fresh key and cleans up expired ones. This prevents credential
# accumulation and limits blast radius if a key leaks.

echo 'Cleaning up expired access keys for service account'
EXPIRED_KEYS=$(nebius iam v2 access-key list-by-account \
  --account-service-account-id "${NEBIUS_SA_TERRAFORM_ID}" \
  --format json \
  --page-size 100 \
  | jq -r '.items[]? | select(.status.state == "EXPIRED") | .metadata.id')

echo "$EXPIRED_KEYS" | while read -r KEY_ID; do
  if [ -n "$KEY_ID" ]; then
    echo "Deleting expired key: ${KEY_ID}"
    nebius iam v2 access-key delete --id "${KEY_ID}" --async || true
  fi
done

DATE_FORMAT='+%Y-%m-%dT%H:%M:%SZ'

if [[ "$(uname)" == "Darwin" ]]; then
  EXPIRATION_DATE=$(date -v +1d "${DATE_FORMAT}")
else
  EXPIRATION_DATE=$(date -d '+1 day' "${DATE_FORMAT}")
fi

echo 'Creating new access key for Object Storage'
NEBIUS_SA_ACCESS_KEY_ID=$(nebius iam v2 access-key create \
  --parent-id "${NEBIUS_PROJECT_ID}" \
  --name "slurm-tf-ak-$(date +%s)" \
  --account-service-account-id "${NEBIUS_SA_TERRAFORM_ID}" \
  --description 'Temporary S3 Access' \
  --expires-at "${EXPIRATION_DATE}" \
  --format json \
  | jq -r '.metadata.id')
echo "Created new access key: ${NEBIUS_SA_ACCESS_KEY_ID}"

# endregion Access key

# region AWS access key
# Convert the Nebius access key into AWS-compatible credentials. Nebius Object
# Storage implements the S3 API, so Terraform's S3 backend works with these.

AWS_ACCESS_KEY_ID=$(nebius iam v2 access-key get \
  --id "${NEBIUS_SA_ACCESS_KEY_ID}" \
  --format json | jq -r '.status.aws_access_key_id')
export AWS_ACCESS_KEY_ID

echo "Generating new AWS_SECRET_ACCESS_KEY"
AWS_SECRET_ACCESS_KEY="$(nebius iam v2 access-key get \
  --id "${NEBIUS_SA_ACCESS_KEY_ID}" \
  --format json \
  | jq -r '.status.secret')"
export AWS_SECRET_ACCESS_KEY

# Query the bucket's actual storage region for the S3 endpoint. Nebius Object
# Storage may be in a different region than compute in some configurations.
NEBIUS_STORAGE_REGION=$(nebius storage bucket list \
  --parent-id "${NEBIUS_PROJECT_ID}" \
  --format json 2>/dev/null \
  | jq -r '.items[0].status.region // "eu-north2"')

AWS_REGION=$NEBIUS_STORAGE_REGION
export AWS_REGION

AWS_ENDPOINT_URL="https://storage.$AWS_REGION.nebius.cloud:443"
export AWS_ENDPOINT_URL

# endregion AWS access key

# region Bucket
# Terraform remote state lives in a versioned S3 bucket. The bucket name is
# deterministic (md5 of tenant+project) so multiple team members and CI systems
# converge on the same bucket. Versioning is enabled so accidental state
# corruption can be recovered from a prior version.

NEBIUS_BUCKET_NAME="tfstate-slurm-k8s-$(echo -n "${NEBIUS_TENANT_ID}-${NEBIUS_PROJECT_ID}" | md5sum | awk '$0=$1')"
export NEBIUS_BUCKET_NAME

EXISTING_BUCKET=$(nebius storage bucket list \
  --parent-id "${NEBIUS_PROJECT_ID}" \
  --format json \
  | jq -r --arg BUCKET "${NEBIUS_BUCKET_NAME}" '.items[]? | select(.metadata.name == $BUCKET) | .metadata.name')

if [ -z "${EXISTING_BUCKET}" ]; then
  nebius storage bucket create \
    --name "${NEBIUS_BUCKET_NAME}" \
    --parent-id "${NEBIUS_PROJECT_ID}" \
    --versioning-policy 'enabled'
  echo "Created bucket: ${NEBIUS_BUCKET_NAME}"
else
  echo "Using existing bucket: ${NEBIUS_BUCKET_NAME}"
fi

# endregion Bucket

# region Backend override
# Generates a Terraform backend config file per path, pointing at the shared S3
# bucket above. This is a file override (terraform_backend_override.tf) rather
# than inline in terraform.tf because the bucket name and credentials are
# dynamic — they come from this script, not from static config. The skip_* flags
# are required because Nebius Object Storage is S3-compatible but not AWS S3.
#
# Each path uses a distinct state key so path-a and soperator never share a
# lock or overwrite each other's state, while still reusing one bucket, one SA,
# and one access key lifecycle.

write_backend_override() {
  local target_file="$1"
  local state_key="$2"
  cat > "${target_file}" << EOF
terraform {
  backend "s3" {
    bucket = "${NEBIUS_BUCKET_NAME}"
    key    = "${state_key}"

    endpoints = {
      s3 = "https://storage.${NEBIUS_STORAGE_REGION}.nebius.cloud:443"
    }
    region = "${NEBIUS_STORAGE_REGION}"

    skip_region_validation      = true
    skip_credentials_validation = true
    skip_requesting_account_id  = true
    skip_s3_checksum            = true
  }
}
EOF
}

# Path B — Soperator (canonical Solutions Library deployment).
write_backend_override \
  "soperator/installations/poc/terraform_backend_override.tf" \
  "slurm-k8s.tfstate"

# Path A — Slinky on MK8s (constrained-quota deployment). State key is
# namespaced so it cannot collide with Path B in the shared bucket.
write_backend_override \
  "terraform/path-a/terraform_backend_override.tf" \
  "path-a/slurm-k8s.tfstate"

# endregion Backend override

# endregion Access key + S3 backend

# endregion Remote state

# region TF variables
# Export all identity/infra values as TF_VAR_* so Terraform picks them up
# automatically without hardcoding in terraform.tfvars. This means the same
# terraform.tfvars works across tenants — only this .envrc changes.

# Path B (Soperator) variable schema — iam_*, vpc_subnet_id, o11y_*, aws_*.
export TF_VAR_region="${NEBIUS_REGION}"
export TF_VAR_iam_tenant_id="${NEBIUS_TENANT_ID}"
export TF_VAR_iam_project_id="${NEBIUS_PROJECT_ID}"
export TF_VAR_o11y_iam_tenant_id="${NEBIUS_OLLY_TENANT_ID}"
export TF_VAR_o11y_profile="${NEBIUS_OLLY_PROFILE}"
export TF_VAR_vpc_subnet_id="${NEBIUS_VPC_SUBNET_ID}"
export TF_VAR_aws_access_key_id="${AWS_ACCESS_KEY_ID}"
export TF_VAR_aws_secret_access_key="${AWS_SECRET_ACCESS_KEY}"

# Path A (Slinky) variable schema — parent_id, subnet_id. Redundant aliases
# rather than a rename so each path keeps its own idiomatic variable names.
export TF_VAR_parent_id="${NEBIUS_PROJECT_ID}"
export TF_VAR_subnet_id="${NEBIUS_VPC_SUBNET_ID}"
# Soperator Terraform creates many resources in sequence; 20 parallelism
# prevents overwhelming the Nebius API while still being faster than serial.
export TFE_PARALLELISM=20

echo ""
echo "=== Environment ready ==="
echo "Region:        ${TF_VAR_region}"
echo "Tenant:        ${TF_VAR_iam_tenant_id}"
echo "Project:       ${TF_VAR_iam_project_id}"
echo "Subnet:        ${TF_VAR_vpc_subnet_id}"
echo "SA:            ${NEBIUS_SA_TERRAFORM_ID}"
echo "S3 bucket:     ${NEBIUS_BUCKET_NAME}"
echo "Parallelism:   ${TFE_PARALLELISM}"
echo "Backend (A):   terraform/path-a/                 key=path-a/slurm-k8s.tfstate"
echo "Backend (B):   soperator/installations/poc/      key=slurm-k8s.tfstate"

# endregion TF variables
